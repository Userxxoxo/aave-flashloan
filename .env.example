# Enhanced DeFi Arbitrage System - Environment Configuration

# =============================================================================
# BLOCKCHAIN NETWORK CONFIGURATION
# =============================================================================

# Primary RPC URLs
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
ARBITRUM_RPC_URL=https://arbitrum-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
OPTIMISM_RPC_URL=https://optimism-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Backup RPC URLs
ETHEREUM_RPC_URL_BACKUP=https://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL_BACKUP=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_RPC_URL_BACKUP=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
OPTIMISM_RPC_URL_BACKUP=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Network Configuration
WEB3_INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================

# Private key for trading wallet (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Initial balance per network (in USD equivalent)
INITIAL_BALANCE_USD=50

# =============================================================================
# CONTRACT ADDRESSES
# =============================================================================

# Flash loan contracts
FLASH_LOAN_CONTRACT_ETHEREUM=0xYourFlashLoanContractHere
FLASH_LOAN_CONTRACT_POLYGON=0xYourFlashLoanContractHere
FLASH_LOAN_CONTRACT_ARBITRUM=0xYourFlashLoanContractHere
FLASH_LOAN_CONTRACT_OPTIMISM=0xYourFlashLoanContractHere

# Arbitrage engine contracts
ARBITRAGE_CONTRACT_ETHEREUM=0xYourArbitrageContractHere
ARBITRAGE_CONTRACT_POLYGON=0xYourArbitrageContractHere
ARBITRAGE_CONTRACT_ARBITRUM=0xYourArbitrageContractHere
ARBITRAGE_CONTRACT_OPTIMISM=0xYourArbitrageContractHere

# =============================================================================
# DEX AND AGGREGATOR API KEYS
# =============================================================================

# 1inch API
ONEINCH_API_KEY=YOUR_1INCH_API_KEY

# 0x API
ZEROX_API_KEY=YOUR_0X_API_KEY

# Paraswap API
PARASWAP_API_KEY=YOUR_PARASWAP_API_KEY

# =============================================================================
# GAS OPTIMIZATION CONFIGURATION
# =============================================================================

# Gas price settings (in gwei)
MAX_GAS_PRICE_GWEI=200
MIN_GAS_PRICE_GWEI=1
TARGET_GAS_PRICE_GWEI=50

# Gas optimization
GAS_LIMIT_BUFFER_PERCENT=20
BASE_FEE_MULTIPLIER=1.125
PRIORITY_FEE_MULTIPLIER=1.2

# =============================================================================
# MEV PROTECTION CONFIGURATION
# =============================================================================

# Flashbots configuration
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_BUNDLE_DELAY=2
ENABLE_MEV_PROTECTION=true

# Private mempool settings
USE_PRIVATE_MEMPOOL=true
ENABLE_BACKRUN_PROTECTION=true
SIMULATION_REQUIRED=true

# =============================================================================
# SLIPPAGE PROTECTION CONFIGURATION
# =============================================================================

# Slippage settings (as decimal, e.g., 0.005 = 0.5%)
DEFAULT_SLIPPAGE_TOLERANCE=0.005
MAX_SLIPPAGE_TOLERANCE=0.02
SLIPPAGE_SAFETY_BUFFER=0.001

# Trade deadline (in seconds)
TRADE_DEADLINE_SECONDS=300

# =============================================================================
# RISK MANAGEMENT CONFIGURATION
# =============================================================================

# Position limits (in USD)
MAX_POSITION_SIZE_USD=10
MAX_DAILY_LOSS_USD=5

# Risk thresholds
MAX_DRAWDOWN_PERCENT=20
STOP_LOSS_THRESHOLD_PERCENT=10
MAX_LEVERAGE=1

# =============================================================================
# PROFIT AND TRADING CONFIGURATION
# =============================================================================

# Minimum profit thresholds (in USD)
MIN_PROFIT_THRESHOLD_USD=0.50
MIN_PROFIT_PERCENTAGE=0.5

# Trading amounts (in native token, e.g., ETH/MATIC)
DEFAULT_TRADE_AMOUNT_ETH=0.1
DEFAULT_TRADE_AMOUNT_MATIC=100
DEFAULT_TRADE_AMOUNT_ARB=0.1
DEFAULT_TRADE_AMOUNT_OP=0.1

# =============================================================================
# MONITORING AND ALERTING
# =============================================================================

# Health check intervals (in seconds)
HEALTH_CHECK_INTERVAL=60
NETWORK_STATUS_UPDATE_INTERVAL=30
PRICE_UPDATE_INTERVAL=15

# Logging configuration
LOG_LEVEL=info
LOG_FILE_PATH=./services/logs/system.log
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=production
PORT=3000

# Cache settings
CACHE_TTL_SECONDS=60
PRICE_CACHE_TTL_SECONDS=30
GAS_CACHE_TTL_SECONDS=60

# Performance settings
MAX_CONCURRENT_TRADES=3
TRADE_TIMEOUT_SECONDS=30
NETWORK_TIMEOUT_SECONDS=10

# =============================================================================
# EXTERNAL SERVICE CONFIGURATION
# =============================================================================

# Price oracles
COINGECKO_API_KEY=YOUR_COINGECKO_API_KEY
CHAINLINK_RPC_URL=https://chainlink-node.example.com

# Gas price oracles
BLOCKNATIVE_API_KEY=YOUR_BLOCKNATIVE_API_KEY
ETHGASSTATION_API_KEY=YOUR_ETHGASSTATION_API_KEY

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# API rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Security settings
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_VALIDATION=true
ENABLE_CORS=false

# =============================================================================
# DEVELOPMENT AND TESTING
# =============================================================================

# Development settings (set to false in production)
ENABLE_DEBUG_MODE=false
ENABLE_TEST_MODE=false
MOCK_EXTERNAL_APIS=false

# Testing configuration
TEST_NETWORK_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_INFURA_PROJECT_ID
TEST_PRIVATE_KEY=your_test_private_key_here
TEST_CONTRACT_ADDRESS=0xYourTestContractHere

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Circuit breaker settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=300
CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=60

# Performance optimization
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_METRICS_INTERVAL=300
ENABLE_MEMORY_MONITORING=true

# Database configuration (if using persistent storage)
DATABASE_URL=postgresql://user:password@localhost:5432/defi_arbitrage
REDIS_URL=redis://localhost:6379

# Notification settings
ENABLE_NOTIFICATIONS=false
WEBHOOK_URL=https://your-webhook-url.com/notify
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK