# =============================================================================
# TYPESCRIPT SERVICES - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# SERVICE CONFIGURATION
# -----------------------------------------------------------------------------
# Service Ports
DEFI_SYSTEM_PORT=3001
NETWORK_MANAGER_PORT=3002
LIQUIDITY_AGGREGATOR_PORT=3003
RISK_MANAGER_PORT=3004
GAS_OPTIMIZER_PORT=3005
MEV_PROTECTION_PORT=3006
SLIPPAGE_PROTECTION_PORT=3007

# Service URLs (for inter-service communication)
DEFI_SYSTEM_URL=http://localhost:3001
NETWORK_MANAGER_URL=http://localhost:3002
LIQUIDITY_AGGREGATOR_URL=http://localhost:3003
RISK_MANAGER_URL=http://localhost:3004

# -----------------------------------------------------------------------------
# NETWORK CONFIGURATION
# -----------------------------------------------------------------------------
# RPC URLs
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Chain IDs
POLYGON_CHAIN_ID=137
ETHEREUM_CHAIN_ID=1
ARBITRUM_CHAIN_ID=42161
OPTIMISM_CHAIN_ID=10

# -----------------------------------------------------------------------------
# API KEYS
# -----------------------------------------------------------------------------
ONEINCH_API_KEY=YOUR_1INCH_API_KEY
ZEROX_API_KEY=YOUR_0X_API_KEY
PARASWAP_API_KEY=YOUR_PARASWAP_API_KEY
COINGECKO_API_KEY=YOUR_COINGECKO_API_KEY
MORALIS_API_KEY=YOUR_MORALIS_API_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID

# -----------------------------------------------------------------------------
# TRADING PARAMETERS
# -----------------------------------------------------------------------------
MIN_PROFIT_USD=1.0
MIN_PROFIT_PERCENTAGE=0.30
MAX_GAS_PRICE_GWEI=50
MAX_SLIPPAGE_PERCENT=2.0
MAX_PRICE_IMPACT_PERCENT=1.0

# -----------------------------------------------------------------------------
# SYSTEM SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
DEBUG_MODE=false
CACHE_TTL=300
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# -----------------------------------------------------------------------------
# MEV & SECURITY
# -----------------------------------------------------------------------------
MEV_PROTECTION_ENABLED=true
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
PRIVATE_MEMPOOL_ENABLED=false

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID