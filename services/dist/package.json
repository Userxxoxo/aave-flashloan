{
  "name": "defi-arbitrage-services",
  "version": "1.0.0",
  "description": "Core DeFi services for enhanced flash loan arbitrage system",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "start:system": "node dist/core/SystemLauncher.js",
    "start:network": "node dist/core/NetworkManager.js",
    "start:liquidity": "node dist/core/LiquidityAggregator.js",
    "start:risk": "node dist/core/RiskManager.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "postbuild": "cp package.json dist/",
    "health-check": "node dist/utils/health-check.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^27.5.2",
    "@types/node": "^12.20.55",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^7.32.0",
    "jest": "^27.5.1",
    "prettier": "^2.8.8",
    "ts-jest": "^27.1.5",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.9.5"
  },
  "keywords": [
    "defi",
    "arbitrage",
    "flashloan",
    "ethereum",
    "polygon",
    "mev",
    "slippage",
    "gas-optimization"
  ],
  "author": "DeFi Arbitrage Team",
  "license": "MIT"
}
